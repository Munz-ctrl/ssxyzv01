{
  "version": 2,
  "functions": {
    "api/dressup/*.js": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/",             "destination": "/index.html" },
    { "source": "/dashboard",    "destination": "/apps/dashboard/dashboard.html" },
    { "source": "/map",          "destination": "/apps/map/map.html" },
    { "source": "/dressup",      "destination": "/apps/tools/dressup/dressup.html" },
    { "source": "/ssx-stylist",  "destination": "/apps/tools/dressup/dressup.html" },
    { "source": "/stylist",      "destination": "/apps/tools/dressup/dressup.html" },
    { "source": "/mannequin",    "destination": "/apps/tools/dressup/dressup.html" },
    { "source": "/nomadsuitcase","destination": "/apps/nomadsuitcase/nomadsuitcase.html" },
    { "source": "/edit-profile", "destination": "/apps/edit/edit-profile.html" },
    { "source": "/puffcounter",  "destination": "/apps/puffcounter/index.html" },
    { "source": "/portfolio",    "destination": "/apps/portfolio/index.html" }
  ],
  "redirects": [
    { "source": "/Nomad_Suitcase.html",       "destination": "/nomadsuitcase", "permanent": true },
    { "source": "/edit-profile.html",         "destination": "/edit-profile",  "permanent": true },
    { "source": "/apps/dressup/dressup.html", "destination": "/dressup",       "permanent": true }
  ]
}
